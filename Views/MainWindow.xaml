<Window x:Class="PlayLimit.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PlayLimit"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0"
                  ItemsSource="{Binding Rules}"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Nama"
                                    Binding="{Binding Name}"/>

                <DataGridTextColumn Header="Process"
                                    Binding="{Binding ProcessName}"/>

                <DataGridTextColumn Header="Limit"
                                    Binding="{Binding TimeLimit}"/>

                <DataGridCheckBoxColumn Header="Aktif"
                                        Binding="{Binding Enabled}"/>

                <DataGridTextColumn
                    Header="Dipakai"
                    Binding="{Binding UsageText}"/>

                <DataGridTextColumn
                    Header="Sisa"
                    Binding="{Binding RemainingMinutes}"/>

                <DataGridTemplateColumn Header="Progress">

                    <DataGridTemplateColumn.CellTemplate>

                        <DataTemplate>

                            <ProgressBar
                                Height="18"
                                Minimum="0"
                                Maximum="1"
                                Value="{Binding Progress, Mode=OneWay}"/>

                        </DataTemplate>

                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">

            <Button Width="100"
                    Height="35"
                    Content="Tambah"
                    Command="{Binding AddRuleCommand}"/>

            <Button
                Width="100"
                Height="35"
                Margin="5,0,0,0"
                Content="Test"
                Command="{Binding TestProcessCommand}"/>

        </StackPanel>

    </Grid>
</Window>